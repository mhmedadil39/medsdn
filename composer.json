{
    "name": "medsdn/medsdn",
    "type": "project",
    "description": "MedSDN Laravel E-Commerce Platform",
    "keywords": [
        "framework",
        "laravel",
        "ecommerce",
        "medical",
        "healthcare"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-calendar": "*",
        "ext-curl": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-tokenizer": "*",
        "api-platform/graphql": "v4.2.3",
        "api-platform/laravel": "v4.1.25",
        "astrotomic/laravel-translatable": "^11.0.0",
        "bagisto/image-cache": "dev-master",
        "barryvdh/laravel-dompdf": "^2.0.0",
        "diglactic/laravel-breadcrumbs": "^9.0",
        "elasticsearch/elasticsearch": "^8.10",
        "enshrined/svg-sanitize": "^0.22.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "intervention/image": "^2.4",
        "kalnoy/nestedset": "^6.0",
        "khaled.alshamaa/ar-php": "^6.0.0",
        "konekt/concord": "^1.2",
        "laravel/framework": "^11.0",
        "laravel/octane": "^2.3",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.0",
        "laravel/tinker": "^2.0",
        "laravel/ui": "^4.0",
        "maatwebsite/excel": "^3.1.46",
        "mll-lab/laravel-graphiql": "^3.1",
        "mpdf/mpdf": "^8.2",
        "nesbot/carbon": "^2.72.2",
        "nuwave/lighthouse": "^6.23",
        "openai-php/laravel": "^0.10.1",
        "paypal/paypal-checkout-sdk": "1.0.1",
        "php-open-source-saver/jwt-auth": "^2.8",
        "predis/predis": "^2.2",
        "prettus/l5-repository": "^2.6",
        "pusher/pusher-php-server": "^7.0",
        "shetabit/visitor": "^4.1",
        "spatie/laravel-responsecache": "^7.4",
        "spatie/laravel-sitemap": "^7.3",
        "stevebauman/purify": "^6.3"
    },
    "require-dev": {
        "bagisto/laravel-datafaker": "2.3.*",
        "barryvdh/laravel-debugbar": "^3.8",
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.1",
        "laravel/pint": "^1.19",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Webkul\\Admin\\": "packages/medsdn/Admin/src",
            "Webkul\\Attribute\\": "packages/medsdn/Attribute/src",
            "Webkul\\BookingProduct\\": "packages/medsdn/BookingProduct/src",
            "Webkul\\CartRule\\": "packages/medsdn/CartRule/src",
            "Webkul\\CatalogRule\\": "packages/medsdn/CatalogRule/src",
            "Webkul\\Category\\": "packages/medsdn/Category/src",
            "Webkul\\Checkout\\": "packages/medsdn/Checkout/src",
            "Webkul\\CMS\\": "packages/medsdn/CMS/src",
            "Webkul\\Core\\": "packages/medsdn/Core/src",
            "Webkul\\Customer\\": "packages/medsdn/Customer/src",
            "Webkul\\DataGrid\\": "packages/medsdn/DataGrid/src",
            "Webkul\\DataTransfer\\": "packages/medsdn/DataTransfer/src",
            "Webkul\\DebugBar\\": "packages/medsdn/DebugBar/src",
            "Webkul\\FPC\\": "packages/medsdn/FPC/src",
            "Webkul\\GDPR\\": "packages/medsdn/GDPR/src",
            "Webkul\\GraphQLAPI\\": "packages/medsdn/GraphQLAPI/src",
            "Webkul\\MedsdnApi\\": "packages/medsdn/MedsdnApi/src",
            "Webkul\\Installer\\": "packages/medsdn/Installer/src",
            "Webkul\\Inventory\\": "packages/medsdn/Inventory/src",
            "Webkul\\MagicAI\\": "packages/medsdn/MagicAI/src",
            "Webkul\\Marketing\\": "packages/medsdn/Marketing/src",
            "Webkul\\Notification\\": "packages/medsdn/Notification/src",
            "Webkul\\Paypal\\": "packages/medsdn/Paypal/src",
            "Webkul\\Payment\\": "packages/medsdn/Payment/src",
            "Webkul\\Product\\": "packages/medsdn/Product/src",
            "Webkul\\Rule\\": "packages/medsdn/Rule/src",
            "Webkul\\Sales\\": "packages/medsdn/Sales/src",
            "Webkul\\Shipping\\": "packages/medsdn/Shipping/src",
            "Webkul\\Shop\\": "packages/medsdn/Shop/src",
            "Webkul\\Sitemap\\": "packages/medsdn/Sitemap/src",
            "Webkul\\SocialLogin\\": "packages/medsdn/SocialLogin/src",
            "Webkul\\SocialShare\\": "packages/medsdn/SocialShare/src",
            "Webkul\\Tax\\": "packages/medsdn/Tax/src",
            "Webkul\\Theme\\": "packages/medsdn/Theme/src",
            "Webkul\\User\\": "packages/medsdn/User/src",
            "Webkul\\GraphQL\\": "packages/medsdn/GraphQL/src",
            "Webkul\\BankTransfer\\": "packages/medsdn/BankTransfer/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Webkul\\Admin\\Tests\\": "packages/medsdn/Admin/tests",
            "Webkul\\Core\\Tests\\": "packages/medsdn/Core/tests",
            "Webkul\\DataGrid\\Tests\\": "packages/medsdn/DataGrid/tests",
            "Webkul\\Installer\\Tests\\": "packages/medsdn/Installer/tests",
            "Webkul\\Shop\\Tests\\": "packages/medsdn/Shop/tests"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-create-project-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "intervention/image",
                "laravel/socialite",
                "shetabit/visitor",
                "api-platform/laravel"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/medsdn/medsdn/issues",
        "forum": "https://forums.medsdn.com",
        "source": "https://github.com/medsdn/medsdn",
        "docs": "https://docs.medsdn.com"
    }
}
